# Mailfold backend configuration.
# Copy to .env and fill in real values.

# HTTP listen address.
MAILFOLD_ADDR=:8080

# Base URL of the mailcow instance (required).
MAILFOLD_MAILCOW_URL=https://mail.cortexus.ru

# mailcow API key (sent as X-API-Key). Create one in the mailcow admin UI.
MAILFOLD_MAILCOW_API_KEY=changeme

# Skip TLS verification when talking to mailcow (development only).
MAILFOLD_MAILCOW_INSECURE_TLS=false

# Directory with the built frontend SPA (optional; API-only if absent).
MAILFOLD_FRONTEND_DIR=./frontend/dist

# Mailfold admin credentials (required). Mailfold authenticates operators itself
# and never exposes the mailcow API key to browsers.
MAILFOLD_ADMIN_USER=admin
MAILFOLD_ADMIN_PASSWORD=changeme

# Session lifetime for issued bearer tokens.
MAILFOLD_SESSION_TTL=12h

# Allowed CORS origins (comma-separated; "*" allows any).
MAILFOLD_CORS_ORIGINS=*

# Login rate limit: max attempts per client IP per window (0 disables).
MAILFOLD_LOGIN_RATE_MAX=5
MAILFOLD_LOGIN_RATE_WINDOW=1m

# Maximum request body size in bytes (0 = unbounded).
MAILFOLD_MAX_BODY_BYTES=1048576
