# Mailfold backend configuration.
# Copy to .env and fill in real values.

# HTTP listen address.
MAILFOLD_ADDR=:8080

# Base URL of the mailcow instance (required).
MAILFOLD_MAILCOW_URL=https://mail.cortexus.ru

# mailcow API key (sent as X-API-Key). Create one in the mailcow admin UI.
MAILFOLD_MAILCOW_API_KEY=changeme

# Skip TLS verification when talking to mailcow (development only).
MAILFOLD_MAILCOW_INSECURE_TLS=false

# Directory with the built frontend SPA (optional; API-only if absent).
MAILFOLD_FRONTEND_DIR=./frontend/dist

# Mailfold admin credentials (required). Mailfold authenticates operators itself
# and never exposes the mailcow API key to browsers.
MAILFOLD_ADMIN_USER=admin
MAILFOLD_ADMIN_PASSWORD=changeme

# Session lifetime for issued bearer tokens.
MAILFOLD_SESSION_TTL=12h

# Allowed CORS origins (comma-separated; "*" allows any).
MAILFOLD_CORS_ORIGINS=*

# Login rate limit: max attempts per client IP per window (0 disables).
MAILFOLD_LOGIN_RATE_MAX=5
MAILFOLD_LOGIN_RATE_WINDOW=1m

# Maximum request body size in bytes (0 = unbounded).
MAILFOLD_MAX_BODY_BYTES=1048576

# Webmail (IMAP/SMTP). Leave MAILFOLD_IMAP_ADDR empty to disable webmail.
MAILFOLD_IMAP_ADDR=127.0.0.1:993
MAILFOLD_SMTP_ADDR=127.0.0.1:587
MAILFOLD_MAIL_TLS=true
MAILFOLD_MAIL_INSECURE_TLS=false
MAILFOLD_WEBMAIL_SESSION_TTL=12h

# Public mail-server hostname shown in the UI status indicator (display-only;
# empty hides it).
MAILFOLD_SERVER_NAME=mail.cortexus.ru

# Storage backend for the DAV and API-key stores. The open-source build supports
# only "sqlite"; the enterprise build also accepts "postgres".
MAILFOLD_DB_DRIVER=sqlite

# DAV groupware + API-key store. A SQLite file path for the sqlite driver, or a
# connection string for postgres. Empty disables DAV endpoints and API keys.
MAILFOLD_DB_PATH=/data/mailfold.db

# Machine-to-machine API keys (send/collect mail over REST without the mailbox
# password). Requires MAILFOLD_DB_PATH set. The master key must be >= 32 bytes
# (hex or base64) and is required only when the feature is enabled.
MAILFOLD_APIKEY_ENABLED=false
MAILFOLD_APIKEY_MASTER_KEY=
# Per-key rate limit (requests per window before HTTP 429).
MAILFOLD_APIKEY_RATE_MAX=120
MAILFOLD_APIKEY_RATE_WINDOW=1m
# Default key expiry applied when a mint request omits one (0 = never expires).
MAILFOLD_APIKEY_DEFAULT_TTL=0
# Cap on total To+Cc+Bcc recipients a single send may target.
MAILFOLD_APIKEY_MAX_RECIPIENTS=50

# Encryption key for the admin account's secrets (a TOTP seed, the
# notification-sender mailbox password). Requires MAILFOLD_DB_PATH set. Must be
# >= 32 bytes (hex or base64). Optional: without it, password change/profile/
# sessions still work, but two-factor auth and the notification sender report
# 501 (the frontend hides those controls instead of offering ones that fail).
MAILFOLD_ADMIN_ENC_KEY=

# Single sign-on (OIDC). Optional: leave any one of these five empty and SSO
# stays fully off (no button, no routes activated). All five must be set
# together for the "Continue with SSO" button to appear on the login screen.
# Only one identity is ever accepted: OIDC_ALLOWED_EMAIL, matched against the
# provider's verified (email_verified=true) email claim.
MAILFOLD_OIDC_ISSUER=
MAILFOLD_OIDC_CLIENT_ID=
MAILFOLD_OIDC_CLIENT_SECRET=
MAILFOLD_OIDC_REDIRECT_URL=
MAILFOLD_OIDC_ALLOWED_EMAIL=
